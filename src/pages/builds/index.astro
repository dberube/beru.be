---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexedRow from '../../components/IndexedRow.astro';
import Screenshot from '../../components/Screenshot.astro';
import { getLiveCollection, number, stackLine, hasBody } from '../../lib/content';
const builds = await getLiveCollection('builds');
---
<BaseLayout title="Builds" description="Products and services I’ve taken from idea to production -- designed, built, launched, and refined around real needs." path="/builds/" image="/og/builds.png">
  <h1>Builds.</h1>
  <p class="prose">Products and services I’ve taken from idea to production -- designed, built, launched, and refined around real needs.</p>

  <section class="section">
    {builds.map((build, i) => (
      <IndexedRow
        number={number(i)}
        meta={build.data.status.toUpperCase()}
        title={build.data.name}
        summary={build.data.summary}
        href={hasBody(build) ? `/builds/${build.id}/` : build.data.url}
        stack={stackLine(build.data.stack)}
      >
        <Screenshot
          src={build.data.screenshot}
          alt={`${build.data.name} screenshot`}
          caption={`${build.data.name} screenshot`}
        />
      </IndexedRow>
    ))}
  </section>
</BaseLayout>
