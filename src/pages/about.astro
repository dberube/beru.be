---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site';
const releases = [

  [
    'v7.0', 
    '2024—Now', 
    'Merck Group (MilliporeSigma)',
    'Group Product Lead',
    'CURRENT — Fortune 100', 
    'Lead eCommerce product at MilliporeSigma, shaping the digital purchasing experience for life science customers across a multibillion-dollar global business.'
  ],

  [
    'v6.0', 
    '2017-2024', 
    'UNFI',
    'Senior Director, Product Management & AI',
    'Fortune 200', 
    'Held senior product and innovation leadership roles at UNFI, leading the development of enterprise commerce platforms, new digital businesses, retail media, and AI capabilities serving thousands of retailers and supporting billions of dollars in annual commerce.'
  ],

  [
    'v5.0', 
    '2016—2017', 
    'WorldBrain, Inc.',
    'Founder & Chief Product Officer',
    'SERIES A STARTUP', 
    'Co-founded WorldBrain and served as Chief Product Officer, building an AI platform designed to predict consumer intent and help brands identify and activate high-value audiences.'
  ],

  [
    'v4.0', 
    '2012-2016', 
    'MojoTech, Inc.',
    'Vice President & Partner',
    'DIGITAL PRODUCT AGENCY - ACQUIRED', 
    'Served as Vice President and Partner at MojoTech, helping lead the agency while advising clients on product strategy, innovation, and the design and development of complex digital products.'
  ],

  [
    'v3.0', 
    '2007—2012', 
    'MoFuse, Inc.',
    'Founder & Chief Product Officer',
    'SERIES B STARTUP — ACQUIRED', 
    'Founded and built MoFuse, a venture-backed platform that made it easy for businesses to create and manage mobile optimized websites and apps without technical expertise. MoFuse grew to tens of thousands of customers worldwide and was later acquired.'
  ],

  [
    'v2.0', 
    '2003—2006', 
    'Yutter',
    'Founder',
    'SEED STARTUP', 
    'Founded and built Yutter, a content distribution platform that automatically delivered newly published blog posts and articles directly to readers’ inboxes.'
  ],

  [
    'v1.0', 
    '2000-2002', 
    'Wireless-IM.com',
    'Founder',
    'SEED STARTUP', 
    'Founded and built Wireless-IM.com, an early web-based messaging product that let people send text messages from their computer directly to mobile phones.'
  ]

];
---
<BaseLayout title="About" description="About David Berube - Product Leader, Builder & Entreprenuer" path="/about/" image="/og/about.png">
  <h1>About.</h1>

  <div class="serif-lede">
    <p>I’m David Berube, a product executive and hands-on builder with more than 20 years of experience creating, launching, and scaling digital products.</p>

    <p>I’ve led product and innovation inside some of the world’s largest companies, building enterprise platforms and new commercial capabilities used by millions of customers and responsible for billions of dollars in commerce.</p>

    <p>I live in Massachusetts and am the father of two amazing daughters. Away from work, I’m usually at a softball/soccer field, a swim meet, in the gym, or reading about technology, geopolitics, and whatever might be worth building next.</p>
  </div>

  <h2 style="margin: 48px 0 -20px 0;">Roles I've Held.</h2>

  <section class="section">

    {releases.map(([version, years, company, title, status, note]) => (
      <div class="list-row">
        <div class="gutter">
          {/* <strong>{version}</strong> */}
          <span>{years}</span>
        </div>
        <div>
          
          <span class="release-status">{status}</span>
          <h3 style="margin: 12px 0 0;">{company}</h3>
          <p style="margin: 4px 0 18px 0; letter-spacing: .04em; color:var(--muted); font-size: 90%; font-weight: 100;" >{title}</p>
          

          <p class="entry-desc">{note}</p>
        </div>
      </div>
    ))}
  </section>

  <p class="lede">
    <a href={site.linkedin}>Full history on LinkedIn →</a>
  </p>

  <p class="serif-lede" style="font-style:italic">"Delight your customers in hard-to-copy, margin enhancing ways" - Gibson Biddle</p>
</BaseLayout>
