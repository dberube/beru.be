---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexedRow from '../../components/IndexedRow.astro';
import { getLiveCollection, number, shortDate } from '../../lib/content';
const essays = await getLiveCollection('writing');
---
<BaseLayout title="Writing" description="What I’ve learned building products, leading teams, and trying new things" path="/writing/" image="/og/writing.png">
  <h1>Writing.</h1>
  <p class="serif-lede">What I’ve learned building products, leading teams, and trying new things before the playbook exists.</p>

  <section class="section">
    {essays.map((essay, i) => (
      <IndexedRow
        number={number(i)}
        meta={shortDate(essay.data.date)}
        title={essay.data.title}
        summary={essay.data.summary}
        href={`/writing/${essay.id}/`}
      />
    ))}
  </section>
</BaseLayout>
