---
import '../styles/global.css';
import { site } from '../site';
interface Props { title?: string; description?: string; path?: string; image?: string; type?: string; }
const { title = site.name, description = site.description, path = '/', image = site.defaultImage, type = 'website' } = Astro.props;
const canonical = new URL(path, site.url).toString();
const pageTitle = title === site.name ? `${site.name} — ${site.shortName}` : `${title} — ${site.name}`;
const imageUrl = new URL(image, site.url).toString();
const current = '/' + (path.split('/').filter(Boolean)[0] ?? '');
const nav = [{href:'/builds',label:'builds'},{href:'/agents',label:'agents'},{href:'/writing',label:'writing'},{href:'/feed',label:'feed'},{href:'/about',label:'about'}];
---
<!doctype html><html lang="en"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title><meta name="description" content={description} /><link rel="canonical" href={canonical} />
<meta property="og:title" content={pageTitle} /><meta property="og:description" content={description} /><meta property="og:type" content={type} /><meta property="og:url" content={canonical} /><meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" /><meta name="twitter:title" content={pageTitle} /><meta name="twitter:description" content={description} /><meta name="twitter:image" content={imageUrl} />
<link rel="alternate" type="application/rss+xml" title="beru.be writing" href="/feed.xml" /></head><body><div class="shell"><header><div class="masthead"><a class="brand" href="/">David Berube</a><nav class="nav" aria-label="Primary">{nav.map((item)=><a href={item.href} data-label={item.label} aria-current={current===item.href?'page':undefined}><span class="slash">/</span>{item.label}</a>)}</nav></div><div class="double-rule"></div></header><main><slot /></main><div class="footer-rule"></div><footer class="site-footer"><div>© {new Date().getFullYear()} David Berube · <a href="/now"><span class="slash">/</span>now</a></div><div><a href={`mailto:${site.email}`}>{site.email}</a> · <a href={site.linkedin}>LinkedIn ↗</a></div></footer></div></body></html>
