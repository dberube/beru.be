---
import { Image } from 'astro:assets';
interface Props { src?: ImageMetadata; alt?: string; href?: string; }
const { src, alt = '', href } = Astro.props;
---
{href ? (
  <a class="screenshot-link" href={href} aria-label={alt || 'Open screenshot'}>
    <figure class="screenshot">{src && <Image src={src} alt={alt} width={960} height={540} loading="lazy" />}</figure>
  </a>
) : (
  <div class="screenshot-link">
    <figure class="screenshot">{src && <Image src={src} alt={alt} width={960} height={540} loading="lazy" />}</figure>
  </div>
)}
