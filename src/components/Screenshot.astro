---
import { Image } from 'astro:assets';
interface Props { src?: ImageMetadata; alt?: string; caption: string; href?: string; }
const { src, alt = '', caption, href } = Astro.props;
---
{href ? (
  <a class="screenshot-link" href={href} aria-label={`Open ${caption}`}>
    <figure class="screenshot">{src ? <Image src={src} alt={alt} width={960} height={540} loading="lazy" /> : <div class="caption">{caption}</div>}</figure>
  </a>
) : (
  <div class="screenshot-link">
    <figure class="screenshot">{src ? <Image src={src} alt={alt} width={960} height={540} loading="lazy" /> : <div class="caption">{caption}</div>}</figure>
  </div>
)}
{src && <div class="caption">{caption}</div>}
